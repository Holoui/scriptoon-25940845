# ──────────────────────────────────────────────────────────────
# Scriptoon — Environment Variables
# ──────────────────────────────────────────────────────────────
# In Lovable, the .env file is auto-generated and managed by Lovable Cloud.
# This file is a reference for self-hosted deployments only.
# Copy to .env and fill in values for local/self-hosted runs.
# Never commit a real .env file.

# ── Frontend (Vite, exposed in client bundle — must be PUBLIC keys only) ──
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# ── Backend / Edge Function secrets ───────────────────────────
# (Set in Supabase Dashboard → Edge Functions → Secrets, or auto-injected by Lovable Cloud.)

# Database / auth (auto-injected on Supabase — only set when self-hosting elsewhere)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # SERVER ONLY — never expose
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# AI (Lovable AI Gateway — used by generate-script, extend-script, generate-cover, try-script)
LOVABLE_API_KEY=lovable_ai_xxxxxxxxxxxxxxxx

# Admin notifications (used by notify-admins edge function)
ADMIN_EMAIL=admin@yourdomain.com

# ── MTN MoMo (mobile money) — momo-request-payment edge function ──
# Get these from https://momodeveloper.mtn.com after creating a Collections subscription.
MOMO_SUBSCRIPTION_KEY=00000000000000000000000000000000
MOMO_API_USER=00000000-0000-0000-0000-000000000000   # UUID provisioned via MoMo /apiuser endpoint
MOMO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx        # generated via /apiuser/{X}/apikey
MOMO_TARGET_ENV=sandbox                              # sandbox | mtnuganda | mtnghana | mtncameroon | …
MOMO_CALLBACK_URL=https://YOUR_PROJECT_REF.functions.supabase.co/momo-callback
